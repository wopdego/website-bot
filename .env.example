# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Google Maps (free $200/mo credit)
GOOGLE_MAPS_API_KEY=your_api_key_here

# Google Calendar OAuth (for AI Receptionist appointment booking)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=https://your-bot.onrender.com/receptionist/oauth/callback

# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM_ID=  # optional, for team projects

# Stripe
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_UPFRONT=price_upfront_500
STRIPE_PRICE_FINAL=price_final_500
STRIPE_PRICE_MONTHLY=price_monthly_99
STRIPE_PRICE_RECEPTIONIST_SETUP=price_receptionist_setup
STRIPE_PRICE_RECEPTIONIST_MONTHLY=price_receptionist_monthly
STRIPE_PRICE_BUNDLE_SETUP=price_bundle_setup

# Site hosting
SITE_DOMAIN=your-bot-domain.com  # where the bot itself is hosted (for previews)

# Outreach (email) - optional
SENDGRID_API_KEY=SG.your_key
FROM_EMAIL=bot@yourdomain.com

# Outreach (SMS) - optional
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Cloudflare (domain registration at cost ~$9/yr per .com)
CLOUDFLARE_API_TOKEN=your_cf_api_token
CLOUDFLARE_ACCOUNT_ID=your_cf_account_id
CF_REGISTRANT_FIRST_NAME=Your
CF_REGISTRANT_LAST_NAME=Name
CF_REGISTRANT_EMAIL=you@email.com
CF_REGISTRANT_PHONE=+17035551234
CF_REGISTRANT_ADDRESS=123 Main St
CF_REGISTRANT_CITY=Manassas
CF_REGISTRANT_STATE=VA
CF_REGISTRANT_ZIP=20109

# Bot settings
PORT=3000
MAX_DAILY_OUTREACH=50
COOLDOWN_DAYS=7
PUBLIC_URL=http://localhost:3000  # your bot's public URL for webhook responses
